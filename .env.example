# App
APP_PORT=3737
NODE_ENV=development

# AI Provider (OpenAI-compatible API — works with Claude, Ollama, etc.)
AI_API_URL=http://localhost:11434/v1
AI_API_KEY=
AI_MODEL=gemma4
AI_SYSTEM_PROMPT=You are an AI assistant helping create and edit Marp markdown presentations. You respond with valid Marp markdown when asked to create or modify slides.

# Storage
STORAGE_PATH=/data/presentations
